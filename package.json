{
  "name": "schedule.pizza",
  "private": true,
  "scripts": {
    "check": "node --test scripts/*.test.mjs && pnpm --filter @schedule.pizza/web check",
    "dev": "pnpm --filter @schedule.pizza/web dev",
    "db": "pnpm --filter @schedule.pizza/web db",
    "build": "pnpm --filter @schedule.pizza/web build",
    "deploy": "pnpm --filter @schedule.pizza/web deploy",
    "lint": "pnpm --filter @schedule.pizza/web lint",
    "smoke": "node scripts/smoke.mjs",
    "smoke-authorized": "node scripts/smoke-authorized.mjs",
    "smoke-live": "node scripts/smoke-live.mjs",
    "typecheck": "pnpm --filter @schedule.pizza/web typecheck",
    "test": "node --test scripts/*.test.mjs && pnpm --filter @schedule.pizza/web test"
  },
  "devDependencies": {
    "@dedalus-labs/hollywood": "0.1.0-alpha.1"
  }
}
